# Copy to `.env` and fill in.
# `.env` is git-ignored.

# Roboflow personal API key (Settings -> API in Roboflow).
ROBOFLOW_API_KEY=
# Public test dataset defaults (override if needed).
ROBOFLOW_WORKSPACE=bus-project-frdgz
ROBOFLOW_PROJECT=passenger-detection-on-a-bus-qgljh
ROBOFLOW_VERSION=1
ROBOFLOW_FORMAT=yolov11

# Weights & Biases project name. Defaults to "bus-passenger-count" if unset.
WANDB_PROJECT=bus-passenger-count
# Team workspace in wandb
WANDB_ENTITY=IA901-2026S1-bus-passenger-count
