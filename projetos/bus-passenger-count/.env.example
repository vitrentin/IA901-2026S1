# Copy to `.env` and fill in.
# `.env` is git-ignored.

# Weights & Biases project name. Defaults to "bus-passenger-count" if unset.
WANDB_PROJECT=bus-passenger-count
# Team workspace in wandb or wandb username if not part of a team
WANDB_ENTITY=IA901-2026S1-bus-passenger-count

# Roboflow API key (required to download Roboflow datasets)
ROBOFLOW_API_KEY=
